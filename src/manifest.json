{
    "manifest_version": 3,
    "name": "Inline Text Completion",
    "version": "1.0",
    "description": "Provides inline text suggestions powered by OpenAI.",
    "permissions": ["storage", "contextMenus", "scripting", "activeTab"],
    "background": {
      "service_worker": "background.js",
      "type": "module"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "css": ["styles.css"]
      }
    ],
    "web_accessible_resources": [
      {
        "resources": ["icon.png"],
        "matches": ["<all_urls>"]
      }
    ],
    "action": {
      "default_icon": {
        "16": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
      }
    }
  }
  