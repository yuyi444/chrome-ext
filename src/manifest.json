{
    "manifest_version": 3,
    "name": "Inline Text Completion",
    "version": "1.0",
    "description": "Provides inline text suggestions powered by OpenAI.",
    "permissions": ["storage"],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "css": ["styles.css"]
      }
    ]
  }