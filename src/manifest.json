{
    "manifest_version": 3,
    "name": "AI Text Enhancer",
    "version": "1.0",
    "description": "Enhance your text with OpenAI suggestions",
    "permissions": [
      "activeTab",
      "storage"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "css": ["styles.css"]
      }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icons/icon.png"
      }
  }
  
  